{
  "name": "@venator-ui/cli",
  "version": "0.1.8",
  "description": "CLI for deploying Venator archetypes and patterns",
  "bin": {
    "venator": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts src/commands/init.ts src/commands/add.ts --format cjs --dts --clean",
    "dev": "tsup src/index.ts --format cjs --watch",
    "manifest": "tsx src/manifest/check.ts",
    "type-check": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist', {recursive: true, force: true})\"",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@venator-ui/archetypes": "0.1.15",
    "@venator-ui/patterns": "*",
    "@venator-ui/tokens": "*",
    "@venator-ui/ui": "*",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "picocolors": "^1.0.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/prompts": "^2.4.9",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
